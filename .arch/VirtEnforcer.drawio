          <mxGeometry height="30" width="120" x="35" y="90" as="geometry" />
        </mxCell>
        <mxCell id="SymfDNkn9KPZp5TBLUak-18" edge="1" parent="1" source="SymfDNkn9KPZp5TBLUak-17" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;dashed=1;sketch=1;curveFitting=1;jiggle=2;shadow=1;" target="SymfDNkn9KPZp5TBLUak-7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="SymfDNkn9KPZp5TBLUak-19" edge="1" parent="1" source="SymfDNkn9KPZp5TBLUak-17" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.25;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;dashed=1;sketch=1;curveFitting=1;jiggle=2;shadow=1;" target="SymfDNkn9KPZp5TBLUak-8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="SymfDNkn9KPZp5TBLUak-20" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;labelPosition=center;verticalLabelPosition=middle;fontFamily=Geist Mono;horizontal=1;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DGeist%2BMono;fontSize=10;sketch=1;curveFitting=1;jiggle=2;shadow=1;" value="&lt;div&gt;&lt;font&gt;How it works?&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;1. Virt-enforcer runs as daemon process&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;2. Connects to Libvirt Broadcast Channel and reacts to the VM_STARTED and VM_RESUMED (Live Migration) events by invoking VMIOPSEnforcement Flow.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;3. Audits the existing VMs (5 worker pools == 5 VMs processes at once) every 10 mins, to pick up volume qos upgrades. Audit also runs on virt-enforce startup as a way to reconcile state.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;4. If any enforcement fails, it triggers a webhook notifier (this workflow is almost done)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Potential Downsides:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;- Audit is fast and optimized (reuses session, caches qos) and completes in less than a second for a VM. (Tests - 16VMs with 27 disks processed in under 500ms).&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;But this could become a bottleneck at scale&lt;/div&gt;" vertex="1">
          <mxGeometry height="310" width="270" x="320" y="160" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
